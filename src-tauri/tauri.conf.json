{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fishing Funds",
  "version": "9.0.0",
  "identifier": "com.electron.1zilc.fishing-funds",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3456",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../release/app/dist/renderer"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Fishing Funds",
        "width": 325,
        "height": 768,
        "minWidth": 300,
        "minHeight": 400,
        "visible": false,
        "decorations": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/1024x1024.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["ff"],
        "name": "Fishing Funds 备份文件",
        "role": "Editor"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": ["https://github.com/1zilc/fishing-funds/releases/latest"],
      "pubkey": ""
    }
  }
}